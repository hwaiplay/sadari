APP_IMAGE=sadari-app:latest
APP_PORT=8080

DB_URL=jdbc:oracle:thin:@//your-rds-endpoint.ap-northeast-2.rds.amazonaws.com:1521/ORCL
DB_USERNAME=sadari
DB_PASSWORD=change-me
DB_CONNECTION_TIMEOUT=60000
DB_MAXIMUM_POOL_SIZE=10
DB_MINIMUM_IDLE=2

FRONT_DOMAIN=https://your-front-domain.com
BACK_DOMAIN=https://your-api-domain.com

JWT_SECRET=replace-with-long-random-base64-compatible-secret
JWT_ACCESS_TOKEN_SECONDS=1800
JWT_REFRESH_TOKEN_SECONDS=86400

KAKAO_REST_API_KEY=change-me
KAKAO_JAVASCRIPT_KEY=change-me
KAKAO_NATIVE_APP_KEY=

NAVER_CLIENT_ID=change-me
NAVER_CLIENT_SECRET=change-me

COOKIE_SECURE=true
COOKIE_SAME_SITE=None

LOGGING_LEVEL_ROOT=info
LOGGING_LEVEL_APP=info
