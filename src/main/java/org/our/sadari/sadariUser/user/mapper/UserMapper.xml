<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.our.sadari.sadariUser.user.mapper.UserMapper">

    <select id="getUser" parameterType="org.our.sadari.sadariUser.user.dto.UserDto" resultType="org.our.sadari.sadariUser.user.dto.UserDto">
        SELECT USER_NUMB
            , JOIN_DATE
            , PROF_PATH
            , USER_IDXX
            , USER_NICK
            , USER_PROV
            , USER_ROLE
          FROM TM_USERXM
        WHERE A.USER_NUMB = #{userNumb}
    </select>
</mapper>